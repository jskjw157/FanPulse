# ─── PostgreSQL Database ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fanpulse
DB_USERNAME=fanpulse
DB_PASSWORD=fanpulse

# ─── Authentication ───
JWT_SECRET=change-me-in-production-at-least-256-bits-long
